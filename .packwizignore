# Files tracked in the repo but excluded from the distributed pack.
# packwiz uses gitignore syntax here, relative to the pack root.

# Export output directory (the .zip we build for CurseForge)
build/

# Browser-automation + branding working artifacts
.playwright-mcp/

# Python lint cache (dev-only cruft, no place in a Minecraft pack)
.ruff_cache/

# Internal dev notes, not for players
docs/
README.md

# Logo/branding assets - uploaded to the CurseForge dashboard, not bundled
# in the pack zip that players download.
branding/
gen/

# Open-source project files + dev tooling - repo scaffolding, NOT pack content.
# Without these, `packwiz refresh` indexes them and they ship to players /
# get synced into instances. Only mods/ and config/ are real pack content.
.github/
tools/
LICENSE
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
CHANGELOG.md
.gitignore
.packwizignore
